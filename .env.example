# Auth.js 시크릿 (미설정 시 개발용 고정값 사용 — 프로덕션 필수)
AUTH_SECRET=replace-with-random-secret

# GitHub OAuth (없으면 GitHub 로그인/Star 동기화 불가)
GITHUB_ID=
GITHUB_SECRET=

# Auth.js URL (로컬 기본값)
AUTH_URL=http://localhost:3000

# 프로덕션에서 Dev Login 강제 활성 (기본: 프로덕션 비활성)
# ENABLE_DEV_LOGIN=true

# Supabase 이전 시 (현재 MVP는 SQLite — 선택)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
